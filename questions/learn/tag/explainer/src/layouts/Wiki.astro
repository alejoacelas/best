---
import { nav, canonical } from '../data/nav';

interface Props {
  title?: string;
  subtitle?: string;
  frontmatter?: { title?: string; subtitle?: string };
}
const props = Astro.props;
const title = props.frontmatter?.title ?? props.title ?? 'Claude Tag, explained';
const subtitle = props.frontmatter?.subtitle ?? props.subtitle;

const cur = canonical(Astro.url.pathname);
const idx = nav.findIndex((n) => n.href === cur);
const prev = idx > 0 ? nav[idx - 1] : null;
const next = idx >= 0 && idx < nav.length - 1 ? nav[idx + 1] : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Claude Tag, explained</title>
    <meta
      name="description"
      content="A short, click-through explainer on Anthropic's Claude Tag: how it works, its memory model, and where the real boundaries are."
    />
  </head>
  <body>
    <button id="menu-toggle" aria-label="Toggle navigation">Contents</button>
    <div class="shell">
      <aside class="sidebar" id="sidebar">
        <a class="brand" href="/">
          <span class="brand-mark">@</span>
          <span class="brand-text">Claude&nbsp;Tag<span class="brand-sub">explained</span></span>
        </a>
        <nav>
          <ol>
            {
              nav.map((n, i) => (
                <li>
                  <a href={n.href} class={n.href === cur ? 'active' : ''}>
                    <span class="num">{String(i + 1).padStart(2, '0')}</span>
                    <span>{n.label}</span>
                  </a>
                </li>
              ))
            }
          </ol>
        </nav>
        <p class="sidebar-foot">
          Dotted terms have a definition on hover. Built from the reading packet.
        </p>
      </aside>

      <main>
        <article>
          <header class="page-head">
            {idx >= 0 && <p class="eyebrow">{String(idx + 1).padStart(2, '0')} — of {nav.length}</p>}
            <h1>{title}</h1>
            {subtitle && <p class="subtitle">{subtitle}</p>}
          </header>

          <div class="prose">
            <slot />
          </div>

          <nav class="pager">
            {
              prev ? (
                <a class="pager-link prev" href={prev.href}>
                  <span class="pager-dir">‹ Previous</span>
                  <span class="pager-title">{prev.label}</span>
                </a>
              ) : (
                <span />
              )
            }
            {
              next && (
                <a class="pager-link next" href={next.href}>
                  <span class="pager-dir">Next ›</span>
                  <span class="pager-title">{next.label}</span>
                </a>
              )
            }
          </nav>
        </article>
      </main>
    </div>

    <script>
      const btn = document.getElementById('menu-toggle');
      const sb = document.getElementById('sidebar');
      btn?.addEventListener('click', () => sb?.classList.toggle('open'));

      // Term tooltips: JS-driven show/hide + viewport-clamped placement.
      // position:fixed means no scrollable ancestor clips them, and a short
      // hide delay lets you move into the card to click its source link.
      const MARGIN = 12,
        GAP = 8;
      let hideTimer = null;
      function position(term, tip) {
        tip.style.maxWidth = Math.min(320, window.innerWidth - 2 * MARGIN) + 'px';
        const tr = term.getBoundingClientRect();
        const tw = tip.offsetWidth,
          th = tip.offsetHeight;
        let left = Math.min(tr.left, window.innerWidth - MARGIN - tw);
        left = Math.max(MARGIN, left);
        let top = tr.bottom + GAP;
        if (top + th > window.innerHeight - MARGIN) top = tr.top - th - GAP;
        tip.style.left = left + 'px';
        tip.style.top = top + 'px';
      }
      function show(term) {
        const tip = term.querySelector('.tooltip');
        if (!tip) return;
        clearTimeout(hideTimer);
        tip.classList.add('show');
        position(term, tip);
      }
      function hide(term) {
        term.querySelector('.tooltip')?.classList.remove('show');
      }
      document.querySelectorAll('.term').forEach((term) => {
        const tip = term.querySelector('.tooltip');
        term.addEventListener('mouseenter', () => show(term));
        term.addEventListener('mouseleave', () => {
          hideTimer = setTimeout(() => hide(term), 160);
        });
        term.addEventListener('focusin', () => show(term));
        term.addEventListener('focusout', (e) => {
          if (!term.contains(e.relatedTarget)) hide(term);
        });
        tip?.addEventListener('mouseenter', () => clearTimeout(hideTimer));
        tip?.addEventListener('mouseleave', () => hide(term));
      });
    </script>

    <style is:global>
      :root {
        --paper: #faf6f0;
        --panel: #f2ebe0;
        --ink: #241d18;
        --muted: #7a6e62;
        --rule: #e6ddd0;
        --accent: #c2603d;
        --accent-soft: #e9c9ba;
        --ok: #3f7d54;
        --warn: #a9722a;
        --code-bg: #efe7db;
        --maxw: 44rem;
        --serif: 'Iowan Old Style', 'Palatino Linotype', Palatino, 'Book Antiqua',
          Georgia, 'Times New Roman', serif;
        --sans: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica,
          Arial, sans-serif;
        --mono: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --paper: #1a1714;
          --panel: #211d18;
          --ink: #ece4da;
          --muted: #9c9083;
          --rule: #322b23;
          --accent: #e0906e;
          --accent-soft: #6a4433;
          --ok: #7bbd90;
          --warn: #d8a35a;
          --code-bg: #262019;
        }
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--serif);
        font-size: 18px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .shell { display: grid; grid-template-columns: 17rem minmax(0, 1fr); }

      /* Sidebar */
      .sidebar {
        position: sticky;
        top: 0;
        align-self: start;
        height: 100vh;
        overflow-y: auto;
        padding: 2rem 1.4rem;
        background: var(--panel);
        border-right: 1px solid var(--rule);
        font-family: var(--sans);
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        color: var(--ink);
        margin-bottom: 1.8rem;
      }
      .brand-mark {
        display: grid;
        place-items: center;
        width: 2rem;
        height: 2rem;
        border-radius: 7px;
        background: var(--accent);
        color: #fff;
        font-weight: 700;
        font-size: 1.1rem;
      }
      .brand-text { font-weight: 650; line-height: 1.15; font-size: 1rem; }
      .brand-sub {
        display: block;
        font-weight: 400;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .sidebar nav ol { list-style: none; margin: 0; padding: 0; }
      .sidebar nav li { margin: 0.1rem 0; }
      .sidebar nav a {
        display: flex;
        gap: 0.7rem;
        align-items: baseline;
        padding: 0.4rem 0.6rem;
        border-radius: 7px;
        text-decoration: none;
        color: var(--muted);
        font-size: 0.92rem;
        transition: background 0.12s, color 0.12s;
      }
      .sidebar nav a:hover { background: rgba(0, 0, 0, 0.04); color: var(--ink); }
      .sidebar nav a.active { background: var(--accent); color: #fff; }
      .sidebar nav a.active .num { color: rgba(255, 255, 255, 0.7); }
      .sidebar nav .num {
        font-variant-numeric: tabular-nums;
        font-size: 0.72rem;
        color: var(--muted);
      }
      .sidebar-foot {
        margin-top: 1.6rem;
        padding-top: 1rem;
        border-top: 1px solid var(--rule);
        font-size: 0.78rem;
        line-height: 1.5;
        color: var(--muted);
      }

      /* Main column */
      main { padding: 3.4rem 2rem 5rem; }
      article { max-width: var(--maxw); margin: 0 auto; }
      .page-head { margin-bottom: 2rem; }
      .eyebrow {
        font-family: var(--sans);
        font-size: 0.75rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin: 0 0 0.7rem;
      }
      h1 {
        font-size: clamp(2rem, 4.5vw, 2.8rem);
        line-height: 1.1;
        letter-spacing: -0.01em;
        margin: 0;
      }
      .subtitle {
        font-size: 1.2rem;
        color: var(--muted);
        margin: 0.7rem 0 0;
        font-style: italic;
      }

      .prose > :first-child { margin-top: 0; }
      .prose h2 {
        font-family: var(--sans);
        font-size: 1.28rem;
        letter-spacing: -0.01em;
        margin: 2.4rem 0 0.8rem;
        padding-top: 1.4rem;
        border-top: 1px solid var(--rule);
      }
      .prose h3 {
        font-family: var(--sans);
        font-size: 1.05rem;
        margin: 1.8rem 0 0.5rem;
      }
      .prose p, .prose li { font-size: 1.05rem; }
      .prose a {
        color: var(--accent);
        text-underline-offset: 2px;
        text-decoration-thickness: 1px;
      }
      .prose strong { font-weight: 650; }
      .prose ul, .prose ol { padding-left: 1.3rem; }
      .prose li { margin: 0.4rem 0; }
      .prose code {
        font-family: var(--mono);
        font-size: 0.86em;
        background: var(--code-bg);
        padding: 0.12em 0.38em;
        border-radius: 5px;
      }
      .prose blockquote {
        margin: 1.4rem 0;
        padding: 0.3rem 0 0.3rem 1.1rem;
        border-left: 3px solid var(--accent-soft);
        color: var(--muted);
        font-style: italic;
      }
      .prose hr { border: none; border-top: 1px solid var(--rule); margin: 2.2rem 0; }

      /* Tables */
      .table-wrap { overflow-x: auto; margin: 1.5rem 0; }
      .prose table {
        border-collapse: collapse;
        width: 100%;
        font-family: var(--sans);
        font-size: 0.92rem;
      }
      .prose th, .prose td {
        text-align: left;
        padding: 0.6rem 0.8rem;
        border-bottom: 1px solid var(--rule);
        vertical-align: top;
      }
      .prose thead th {
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .prose tbody tr:hover { background: rgba(0, 0, 0, 0.02); }
      .prose td:first-child { font-weight: 600; color: var(--ink); }

      /* Term tooltip — position:fixed + JS placement so no ancestor overflow
         (e.g. a scrollable table) can clip it, and the card is hoverable. */
      .term {
        border-bottom: 1.5px dotted var(--accent);
        cursor: help;
        outline: none;
      }
      .term:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 2px;
      }
      .tooltip {
        position: fixed;
        left: 0;
        top: 0;
        z-index: 60;
        width: max-content;
        max-width: 20rem;
        background: var(--ink);
        color: var(--paper);
        font-family: var(--sans);
        font-size: 0.83rem;
        font-style: normal;
        line-height: 1.5;
        padding: 0.7rem 0.8rem;
        border-radius: 10px;
        box-shadow: 0 10px 34px rgba(0, 0, 0, 0.28);
        opacity: 0;
        visibility: hidden;
        transform: translateY(-3px);
        transition: opacity 0.13s ease, transform 0.13s ease;
        pointer-events: none;
      }
      .tooltip.show {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        pointer-events: auto;
      }
      .tooltip-term {
        display: block;
        font-weight: 650;
        color: #fff;
        margin-bottom: 0.25rem;
      }
      @media (prefers-color-scheme: dark) {
        .tooltip-term { color: var(--paper); }
      }
      .tooltip-foot {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 0.9rem;
        align-items: center;
        margin-top: 0.55rem;
        padding-top: 0.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.16);
      }
      .tooltip-src,
      .tooltip-more {
        font-size: 0.75rem;
        text-decoration: none;
        white-space: nowrap;
      }
      .tooltip-more { color: var(--accent); }
      .tooltip-src.src-official { color: #8fd0a3; }
      .tooltip-src.src-reported { color: #e2b06a; }
      .tooltip-src:hover,
      .tooltip-more:hover { text-decoration: underline; }

      /* Inline source tag (the (official)/(reported) links) */
      .src {
        font-family: var(--sans);
        font-size: 0.74em;
        font-weight: 500;
        font-style: normal;
        white-space: nowrap;
        text-decoration: none;
        vertical-align: baseline;
      }
      .src.src-official { color: var(--ok); }
      .src.src-reported { color: var(--warn); }
      .src:hover { text-decoration: underline; }
      .src .src-ext { font-size: 0.85em; opacity: 0.7; }
      td .src, th .src { font-size: 0.82em; }

      /* Callouts */
      .callout {
        margin: 1.6rem 0;
        padding: 1rem 1.1rem;
        border-radius: 10px;
        border: 1px solid var(--rule);
        background: var(--panel);
      }
      .callout-label {
        display: block;
        font-family: var(--sans);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.35rem;
      }
      .callout-body > :first-child { margin-top: 0; }
      .callout-body > :last-child { margin-bottom: 0; }
      .callout-body p { font-size: 0.98rem; }
      .callout-unknown {
        border-color: var(--accent-soft);
        background: color-mix(in srgb, var(--accent) 8%, var(--panel));
      }
      .callout-unknown .callout-label { color: var(--accent); }
      .callout-key {
        border: none;
        background: var(--ink);
        color: var(--paper);
      }
      .callout-key .callout-label { color: var(--accent-soft); }
      .callout-key a { color: var(--accent-soft); }

      /* Glossary page */
      .glossary { margin: 0; }
      .glossary dt {
        font-family: var(--sans);
        font-weight: 650;
        font-size: 1.02rem;
        margin-top: 1.5rem;
        scroll-margin-top: 1.5rem;
      }
      .glossary dt:target {
        color: var(--accent);
      }
      .glossary dd { margin: 0.3rem 0 0; color: var(--ink); }

      /* Pager */
      .pager {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 3.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--rule);
      }
      .pager-link {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        text-decoration: none;
        font-family: var(--sans);
        padding: 0.7rem 1rem;
        border: 1px solid var(--rule);
        border-radius: 10px;
        min-width: 42%;
        transition: border-color 0.12s, background 0.12s;
      }
      .pager-link:hover { border-color: var(--accent); background: var(--panel); }
      .pager-link.next { text-align: right; margin-left: auto; }
      .pager-dir { font-size: 0.74rem; color: var(--accent); letter-spacing: 0.04em; }
      .pager-title { font-size: 1rem; color: var(--ink); font-weight: 600; }

      /* Mobile */
      #menu-toggle {
        display: none;
        position: fixed;
        z-index: 100;
        top: 0.8rem;
        left: 0.8rem;
        font-family: var(--sans);
        font-size: 0.85rem;
        padding: 0.5rem 0.9rem;
        border: 1px solid var(--rule);
        border-radius: 8px;
        background: var(--panel);
        color: var(--ink);
      }
      @media (max-width: 820px) {
        .shell { grid-template-columns: 1fr; }
        .sidebar {
          position: fixed;
          z-index: 90;
          top: 0;
          left: 0;
          width: 15rem;
          transform: translateX(-100%);
          transition: transform 0.2s ease;
        }
        .sidebar.open { transform: translateX(0); }
        #menu-toggle { display: block; }
        main { padding: 4.2rem 1.2rem 4rem; }
      }
    </style>
  </body>
</html>
